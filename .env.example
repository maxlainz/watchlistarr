# Proceso
HTTP_PORT=8080
LOG_LEVEL=info
LOG_FORMAT=plain
# SQLite con ruta absoluta (4 slashes) en Docker, relativa (3) en dev local.
DATABASE_URL=sqlite+aiosqlite:////data/watchlistarr.db
# El default se deriva de la versión instalada (watchlistarr/<version>); normalmente dejar sin definir.
# USER_AGENT=watchlistarr/x.y.z (+https://github.com/maxlainz/watchlistarr)

# Corta todo HTTP a Letterboxd; útil para tests.
# LETTERBOXD_OFFLINE=false

# Frecuencias: defaults inmutables en runtime (cambiar = editar .env + reiniciar).
# La UI permite overrides por-lista/por-watchlist (intervalos incremental/full y anti-flap).
# RSS_INTERVAL, FILMS_BACKSTOP_INTERVAL, DISCOVERY_INTERVAL y ROTATION_TICK_INTERVAL son solo-env.
RSS_INTERVAL=15m
WATCHLIST_INCREMENTAL_INTERVAL=1h
WATCHLIST_FULL_INTERVAL=24h
LISTS_INCREMENTAL_INTERVAL=6h
LISTS_FULL_INTERVAL=7d
FILMS_BACKSTOP_INTERVAL=24h
DISCOVERY_INTERVAL=7d
ROTATION_TICK_INTERVAL=1h

# Anti-flap
FLAP_CONFIRM_SCRAPES=3
